function AnimController:ApplyPose(targets, alpha)
	for key, motor in pairs(self.Motors) do
		if motor and self.BaseC0[key] then
			local offset = targets[key] or CFrame.new()
			motor.C0 = Clerp(motor.C0, self.BaseC0[key] * offset, alpha)
		end
	end
end
function AnimController:Update(dt)
	if not character or not root or not humanoid or humanoid.Health <= 0 then
		return
	end
	self.Sine += dt * 8
	local locked = self.StateEndsAt > os.clock()
	if not locked then
		self.State = self:AutoState()
	end
	if self.State == "Airwalk" then
		local camera = workspace.CurrentCamera
		local look = camera and camera.CFrame.LookVector or root.CFrame.LookVector
		local right = camera and camera.CFrame.RightVector or root.CFrame.RightVector
		local move = (look * airwalkDirection.Z) + (right * airwalkDirection.X) + Vector3.new(0, airwalkDirection.Y, 0)
		root.AssemblyLinearVelocity = move * 34 + Vector3.new(0, math.sin(os.clock() * 3) * 1.2, 0)
		local flatLook = Vector3.new(look.X, 0, look.Z)
		if flatLook.Magnitude > 0.05 then
			root.CFrame = root.CFrame:Lerp(CFrame.new(root.Position, root.Position + flatLook), 0.18)
		end
	elseif self.State == "Kurohitsugi" or self.State == "Reiatsu" or self.State == "Hover" then
		root.AssemblyLinearVelocity = Vector3.new(0, math.sin(os.clock() * 3) * 1.5, 0)
		root.CFrame = root.CFrame:Lerp(root.CFrame + Vector3.new(0, math.sin(os.clock() * 3) * 0.03, 0), 0.4)
	end
	if not locked and self.State == "Move" then
		return
	end
	local alpha = locked and 0.18 or 0.08
	self:ApplyPose(self:TargetPose(self.State), alpha)
end
