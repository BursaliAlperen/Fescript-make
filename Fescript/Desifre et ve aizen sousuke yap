local function findFrontTarget(range, arc)
	local bestModel = nil
	local bestRoot = nil
	local bestDistance = range or 45
	local forward = root.CFrame.LookVector
	for _, model in ipairs(workspace:GetChildren()) do
		if model:IsA("Model") and model ~= character then
			local enemyHumanoid = model:FindFirstChildOfClass("Humanoid")
			local enemyRoot = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("Torso") or model:FindFirstChild("UpperTorso")
			if enemyHumanoid and enemyRoot and enemyHumanoid.Health > 0 then
				local delta = enemyRoot.Position - root.Position
				local distance = delta.Magnitude
				if distance <= bestDistance and distance > 1 then
					local dot = forward:Dot(delta.Unit)
					if dot >= (arc or 0.25) then
						bestModel = model
						bestRoot = enemyRoot
						bestDistance = distance
					end
				end
			end
		end
	end
	return bestModel, bestRoot
end
