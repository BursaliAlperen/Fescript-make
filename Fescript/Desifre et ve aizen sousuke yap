local function createIntroGui(onComplete)
    local gui = Instance.new("ScreenGui")
    gui.Name = "RobloxGlop_Aizen_Loader"
    gui.IgnoreGuiInset = true
    gui.ResetOnSpawn = false
    gui.Parent = playerGui

    local shade = Instance.new("Frame")
    shade.BackgroundColor3 = Color3.fromRGB(3, 1, 10)
    shade.BackgroundTransparency = 0.08
    shade.BorderSizePixel = 0
    shade.Size = UDim2.fromScale(1, 1)
    shade.Parent = gui

    local card = Instance.new("Frame")
    card.AnchorPoint = Vector2.new(0.5, 0.5)
    card.BackgroundColor3 = Color3.fromRGB(13, 8, 26)
    card.BorderSizePixel = 0
    card.Position = UDim2.fromScale(0.5, 0.5)
    card.Size = UDim2.fromOffset(520, 275)
    card.Parent = shade

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 18)
    corner.Parent = card

    local stroke = Instance.new("UIStroke")
    stroke.Color = ACCENT
    stroke.Thickness = 2
    stroke.Transparency = 0.15
    stroke.Parent = card

    local title = Instance.new("TextLabel")
    title.BackgroundTransparency = 1
    title.Font = Enum.Font.GothamBlack
    title.Position = UDim2.fromOffset(28, 24)
    title.Size = UDim2.new(1, -56, 0, 44)
    title.Text = "RobloxGlop FE Aizen"
    title.TextColor3 = WHITE
    title.TextScaled = true
    title.TextXAlignment = Enum.TextXAlignment.Left
    title.Parent = card

    local subtitle = Instance.new("TextLabel")
    subtitle.BackgroundTransparency = 1
    subtitle.Font = Enum.Font.GothamSemibold
    subtitle.Position = UDim2.fromOffset(30, 78)
    subtitle.Size = UDim2.new(1, -60, 0, 32)
    subtitle.Text = "script loading..."
    subtitle.TextColor3 = GOLD
    subtitle.TextScaled = true
    subtitle.TextXAlignment = Enum.TextXAlignment.Left
    subtitle.Parent = card

    local barBack = Instance.new("Frame")
    barBack.BackgroundColor3 = Color3.fromRGB(32, 22, 54)
    barBack.BorderSizePixel = 0
    barBack.Position = UDim2.fromOffset(30, 128)
    barBack.Size = UDim2.new(1, -60, 0, 12)
    barBack.Parent = card

    local barCorner = Instance.new("UICorner")
    barCorner.CornerRadius = UDim.new(1, 0)
    barCorner.Parent = barBack

    local bar = Instance.new("Frame")
    bar.BackgroundColor3 = ACCENT
    bar.BorderSizePixel = 0
    bar.Size = UDim2.fromScale(0, 1)
    bar.Parent = barBack

    local fillCorner = Instance.new("UICorner")
    fillCorner.CornerRadius = UDim.new(1, 0)
    fillCorner.Parent = bar

    local languageHolder = Instance.new("Frame")
    languageHolder.BackgroundTransparency = 1
    languageHolder.Position = UDim2.fromOffset(30, 166)
    languageHolder.Size = UDim2.new(1, -60, 0, 54)
    languageHolder.Visible = false
    languageHolder.Parent = card

    local layout = Instance.new("UIListLayout")
    layout.FillDirection = Enum.FillDirection.Horizontal
    layout.Padding = UDim.new(0, 10)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.Parent = languageHolder

    tween(bar, 1.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out, {Size = UDim2.fromScale(1, 1)})

    task.delay(1.28, function()
        subtitle.Text = TRANSLATIONS.tr.pick
        languageHolder.Visible = true
        for code, text in pairs(TRANSLATIONS) do
            local button = Instance.new("TextButton")
            button.BackgroundColor3 = Color3.fromRGB(25, 16, 42)
            button.BorderSizePixel = 0
            button.Font = Enum.Font.GothamBlack
            button.Size = UDim2.fromOffset(78, 46)
            button.Text = text.button
            button.TextColor3 = WHITE
            button.TextScaled = true
            button.Parent = languageHolder

            local buttonCorner = Instance.new("UICorner")
            buttonCorner.CornerRadius = UDim.new(0, 12)
            buttonCorner.Parent = button

            local buttonStroke = Instance.new("UIStroke")
            buttonStroke.Color = GOLD
            buttonStroke.Transparency = 0.45
            buttonStroke.Parent = button

            button.MouseEnter:Connect(function()
                tween(button, 0.16, Enum.EasingStyle.Sine, Enum.EasingDirection.Out, {BackgroundColor3 = ACCENT})
            end)

            button.MouseLeave:Connect(function()
                tween(button, 0.16, Enum.EasingStyle.Sine, Enum.EasingDirection.Out, {BackgroundColor3 = Color3.fromRGB(25, 16, 42)})
            end)

            button.MouseButton1Click:Connect(function()
                selectedLanguage = code
                local chosen = TRANSLATIONS[selectedLanguage]
                subtitle.Text = chosen.ready
                notify(chosen.title, chosen.tip, 6)
                sendChatMessage(chosen.chat)
                flash(ACCENT, 0.16, 0.45)
                petalBurst(root.Position + Vector3.new(0, 3, 0), 28, GOLD, 0.75)
                tween(card, 0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.In, {Position = UDim2.fromScale(0.5, 0.44), BackgroundTransparency = 1})
                tween(shade, 0.35, Enum.EasingStyle.Sine, Enum.EasingDirection.In, {BackgroundTransparency = 1})
                Debris:AddItem(gui, 0.45)
                onComplete()
            end)
        end
    end)
end

local function installTools()
    createTool("Kyoka Suigetsu", "", 4, kyokaSuigetsu)
    createTool("Hado 90: Kurohitsugi", "", 9, kurohitsugi)
    createTool("Hado 63: Raikoho", "", 5, raikoho)
    createTool("Shunpo", "", 3, shunpo)
    createTool("Reiatsu Crush", "", 7, reiatsuCrush)
end

installTools()
installKeyboardShortcuts()
installAmbientAura()
createIntroGui(function()
    local text = TRANSLATIONS[selectedLanguage]
    print("[RobloxGlop FE Aizen] " .. text.ready .. " " .. text.tip)
end)
