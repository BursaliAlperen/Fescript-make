--[[
    FE Aizen Sousuke Tool Suite (deobfuscated rewrite)
    Drop this LocalScript into an executor or StarterPlayerScripts.
    It creates a tool-based, client-side Aizen inspired kit with cinematic VFX,
    procedural animations, cooldowns, and no chat spam.
]]

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local Debris = game:GetService("Debris")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Lighting = game:GetService("Lighting")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local root = character:WaitForChild("HumanoidRootPart")
local backpack = player:WaitForChild("Backpack")

local KIT_NAME = "Aizen Sousuke // FE"
local ACCENT = Color3.fromRGB(176, 90, 255)
local DARK = Color3.fromRGB(10, 4, 22)
local GOLD = Color3.fromRGB(255, 209, 122)
local LIGHTNING = Color3.fromRGB(182, 215, 255)

local rng = Random.new()
local activeCooldowns = {}
local cleanupBin = Instance.new("Folder")
cleanupBin.Name = "Aizen_FE_VFX"
cleanupBin.Parent = workspace

local function refreshCharacter(newCharacter)
    character = newCharacter
    humanoid = character:WaitForChild("Humanoid")
    root = character:WaitForChild("HumanoidRootPart")
end

player.CharacterAdded:Connect(refreshCharacter)

local function tween(instance, time, style, direction, properties)
    local info = TweenInfo.new(time, style or Enum.EasingStyle.Quad, direction or Enum.EasingDirection.Out)
    local animation = TweenService:Create(instance, info, properties)
    animation:Play()
    return animation
end

local function makePart(name, size, cframe, color, material, transparency)
    local part = Instance.new("Part")
    part.Name = name
    part.Anchored = true
    part.CanCollide = false
    part.CanTouch = false
    part.CanQuery = false
    part.CastShadow = false
    part.Size = size
    part.CFrame = cframe
    part.Color = color
    part.Material = material or Enum.Material.Neon
    part.Transparency = transparency or 0
    part.Parent = cleanupBin
    return part
end

local function makeSound(name, soundId, volume, speed, parent)
    local sound = Instance.new("Sound")
    sound.Name = name
    sound.SoundId = soundId
    sound.Volume = volume or 0.6
    sound.PlaybackSpeed = speed or 1
    sound.RollOffMaxDistance = 90
    sound.Parent = parent or root
    sound:Play()
    Debris:AddItem(sound, 6)
    return sound
end

local function flash(color, intensity, duration)
    local effect = Instance.new("ColorCorrectionEffect")
    effect.Name = "AizenFlash"
    effect.TintColor = color
    effect.Brightness = intensity
    effect.Contrast = 0.2
    effect.Saturation = -0.05
    effect.Parent = Lighting
    tween(effect, duration, Enum.EasingStyle.Sine, Enum.EasingDirection.Out, {
        Brightness = 0,
        Contrast = 0,
        Saturation = 0,
        TintColor = Color3.new(1, 1, 1),
    })
    Debris:AddItem(effect, duration + 0.15)
end

local function ring(cframe, radius, color, lifetime, thickness)
    local part = makePart("Spiritual Pressure Ring", Vector3.new(radius, thickness or 0.18, radius), cframe, color, Enum.Material.Neon, 0.18)
    part.Shape = Enum.PartType.Cylinder
    tween(part, lifetime, Enum.EasingStyle.Quint, Enum.EasingDirection.Out, {
        Size = Vector3.new(radius * 2.1, thickness or 0.18, radius * 2.1),
        Transparency = 1,
    })
    Debris:AddItem(part, lifetime + 0.1)
    return part
end

local function orb(position, radius, color, lifetime)
    local part = makePart("Reiatsu Orb", Vector3.new(radius, radius, radius), CFrame.new(position), color, Enum.Material.Neon, 0.05)
    part.Shape = Enum.PartType.Ball
    tween(part, lifetime, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out, {
        Size = Vector3.new(radius * 2.8, radius * 2.8, radius * 2.8),
        Transparency = 1,
    })
    Debris:AddItem(part, lifetime + 0.05)
    return part
end

local function beamBetween(name, startPosition, endPosition, color, width, lifetime)
    local midpoint = (startPosition + endPosition) / 2
    local distance = (startPosition - endPosition).Magnitude
    local part = makePart(name, Vector3.new(width, width, distance), CFrame.new(midpoint, endPosition), color, Enum.Material.Neon, 0.08)
    tween(part, lifetime, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, {
        Size = Vector3.new(width * 0.15, width * 0.15, distance),
        Transparency = 1,
    })
    Debris:AddItem(part, lifetime + 0.05)
    return part
end

local function bladeTrail(duration)
    local hand = character:FindFirstChild("RightHand") or character:FindFirstChild("Right Arm")
    if not hand then
        return
    end

    local attachment0 = Instance.new("Attachment")
    attachment0.Name = "AizenTrailStart"
    attachment0.Position = Vector3.new(0, -0.7, 0)
    attachment0.Parent = hand

    local attachment1 = Instance.new("Attachment")
    attachment1.Name = "AizenTrailEnd"
    attachment1.Position = Vector3.new(0, -2.2, 0)
    attachment1.Parent = hand

    local trail = Instance.new("Trail")
    trail.Name = "Kyoka Suigetsu Afterimage"
    trail.Attachment0 = attachment0
    trail.Attachment1 = attachment1
    trail.Color = ColorSequence.new(GOLD, ACCENT)
    trail.LightEmission = 1
    trail.Lifetime = 0.18
    trail.MinLength = 0.08
    trail.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0.05),
        NumberSequenceKeypoint.new(1, 1),
    })
    trail.Parent = hand

    Debris:AddItem(trail, duration)
    Debris:AddItem(attachment0, duration)
    Debris:AddItem(attachment1, duration)
end

local function ghostClone(offset, lifetime)
    local wasArchivable = character.Archivable
    character.Archivable = true
    local clone = character:Clone()
    character.Archivable = wasArchivable
    clone.Name = "Kyoka Suigetsu Illusion"
    clone.Parent = cleanupBin

    for _, descendant in ipairs(clone:GetDescendants()) do
        if descendant:IsA("BasePart") then
            descendant.Anchored = true
            descendant.CanCollide = false
            descendant.CanTouch = false
            descendant.CanQuery = false
            descendant.Material = Enum.Material.ForceField
            descendant.Color = ACCENT
            descendant.Transparency = 0.35
            tween(descendant, lifetime, Enum.EasingStyle.Sine, Enum.EasingDirection.Out, {Transparency = 1})
        elseif descendant:IsA("Decal") or descendant:IsA("Texture") then
            descendant.Transparency = 0.8
        elseif descendant:IsA("Script") or descendant:IsA("LocalScript") then
            descendant:Destroy()
        end
    end

    clone:PivotTo(root.CFrame * CFrame.new(offset))
    Debris:AddItem(clone, lifetime + 0.1)
    return clone
end

local function cooldown(tool, seconds)
    if activeCooldowns[tool] then
        return false
    end

    activeCooldowns[tool] = true
    local originalName = tool.Name
    task.spawn(function()
        for remaining = seconds, 1, -1 do
            tool.Name = string.format("%s [%ds]", originalName, remaining)
            task.wait(1)
        end
        tool.Name = originalName
        activeCooldowns[tool] = nil
    end)

    return true
end

local function createTool(name, icon, cooldownSeconds, callback)
    local tool = Instance.new("Tool")
    tool.Name = name
    tool.ToolTip = KIT_NAME .. " | " .. name
    tool.TextureId = icon or ""
    tool.RequiresHandle = false
    tool.CanBeDropped = false
    tool.Parent = backpack

    tool.Activated:Connect(function()
        if not character or not root or humanoid.Health <= 0 then
            return
        end
        if cooldown(tool, cooldownSeconds) then
            callback(tool)
        end
    end)

    return tool
end

local function kyokaSuigetsu()
    flash(ACCENT, 0.18, 0.45)
    makeSound("Kyoka Draw", "rbxassetid://9125402735", 0.45, 1.15, root)
    bladeTrail(1.1)

    local origin = root.CFrame
    ring(origin * CFrame.Angles(math.rad(90), 0, 0), 5, ACCENT, 0.65, 0.12)
    orb(root.Position + Vector3.new(0, 2.7, 0), 1.2, ACCENT, 0.45)

    for i = 1, 7 do
        local angle = (math.pi * 2 / 7) * i
        local offset = Vector3.new(math.cos(angle) * 6, 0, math.sin(angle) * 6)
        task.delay(i * 0.045, function()
            ghostClone(offset, 0.75)
            beamBetween("Hypnosis Thread", root.Position + Vector3.new(0, 2, 0), root.Position + offset + Vector3.new(0, 2, 0), ACCENT, 0.08, 0.3)
        end)
    end
end

local function kurohitsugi()
    flash(DARK, 0.28, 0.7)
    makeSound("Black Coffin Charge", "rbxassetid://9126299510", 0.65, 0.8, root)

    local center = root.CFrame * CFrame.new(0, 0, -13)
    ring(center * CFrame.Angles(math.rad(90), 0, 0), 8, DARK, 0.8, 0.2)

    local pillars = {}
    for i = 1, 12 do
        local angle = (math.pi * 2 / 12) * i
        local x = math.cos(angle) * 5.2
        local z = math.sin(angle) * 5.2
        local pillar = makePart("Hado 90 Kurohitsugi Wall", Vector3.new(0.45, 0.2, 0.45), center * CFrame.new(x, 0, z), DARK, Enum.Material.Neon, 0.1)
        pillars[#pillars + 1] = pillar
        task.delay(i * 0.025, function()
            tween(pillar, 0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out, {
                Size = Vector3.new(0.45, 18, 0.45),
                CFrame = pillar.CFrame * CFrame.new(0, 9, 0),
            })
        end)
    end

    task.delay(0.42, function()
        makeSound("Black Coffin Slam", "rbxassetid://9125652147", 0.9, 0.72, root)
        orb(center.Position + Vector3.new(0, 8, 0), 4.5, Color3.fromRGB(52, 17, 91), 0.55)
        for i = 1, 18 do
            local slashStart = center.Position + Vector3.new(rng:NextNumber(-5, 5), rng:NextNumber(2, 15), rng:NextNumber(-5, 5))
            local slashEnd = slashStart + Vector3.new(rng:NextNumber(-3, 3), rng:NextNumber(-5, 1), rng:NextNumber(-3, 3))
            task.delay(i * 0.015, function()
                beamBetween("Kurohitsugi Severing Line", slashStart, slashEnd, ACCENT, 0.12, 0.28)
            end)
        end
        for _, pillar in ipairs(pillars) do
            tween(pillar, 0.42, Enum.EasingStyle.Quart, Enum.EasingDirection.In, {Transparency = 1, Size = Vector3.new(0.1, 20, 0.1)})
            Debris:AddItem(pillar, 0.5)
        end
    end)
end

local function raikoho()
    flash(LIGHTNING, 0.22, 0.35)
    makeSound("Raikoho Charge", "rbxassetid://9125800125", 0.55, 1.35, root)

    local hand = character:FindFirstChild("RightHand") or character:FindFirstChild("Right Arm") or root
    local startPosition = hand.Position + root.CFrame.LookVector * 1.5
    local endPosition = startPosition + root.CFrame.LookVector * 80

    orb(startPosition, 1.6, LIGHTNING, 0.35)
    task.delay(0.16, function()
        makeSound("Raikoho Release", "rbxassetid://9126150731", 0.75, 1.2, root)
        beamBetween("Hado 63 Raikoho", startPosition, endPosition, LIGHTNING, 2.4, 0.32)
        beamBetween("Raikoho Core", startPosition, endPosition, Color3.new(1, 1, 1), 0.7, 0.22)
        for i = 1, 10 do
            local jitter = Vector3.new(rng:NextNumber(-4, 4), rng:NextNumber(-4, 4), rng:NextNumber(-4, 4))
            task.delay(i * 0.018, function()
                beamBetween("Forked Lightning", startPosition, endPosition + jitter, LIGHTNING, 0.18, 0.2)
            end)
        end
        ring(CFrame.new(endPosition) * CFrame.Angles(math.rad(90), 0, 0), 5, LIGHTNING, 0.45, 0.12)
    end)
end

local function shunpo()
    makeSound("Shunpo", "rbxassetid://9126098978", 0.5, 1.45, root)
    ghostClone(Vector3.zero, 0.45)
    flash(Color3.fromRGB(230, 230, 255), 0.12, 0.2)

    local start = root.CFrame
    local destination = start + start.LookVector * 28
    humanoid:ChangeState(Enum.HumanoidStateType.Physics)
    root.CFrame = destination
    task.delay(0.1, function()
        if humanoid then
            humanoid:ChangeState(Enum.HumanoidStateType.Running)
        end
    end)

    for i = 1, 5 do
        task.delay(i * 0.025, function()
            ring(start:Lerp(destination, i / 5) * CFrame.Angles(math.rad(90), 0, 0), 2.5 + i, ACCENT, 0.35, 0.08)
        end)
    end
end

local function reiatsuCrush()
    flash(ACCENT, 0.2, 0.6)
    makeSound("Spiritual Pressure", "rbxassetid://9125838794", 0.8, 0.68, root)

    for i = 1, 8 do
        task.delay(i * 0.07, function()
            ring(root.CFrame * CFrame.Angles(math.rad(90), 0, 0), 3 + i * 2.4, i % 2 == 0 and GOLD or ACCENT, 0.6, 0.16)
        end)
    end

    local aura = orb(root.Position + Vector3.new(0, 1.8, 0), 4, ACCENT, 0.9)
    aura.Transparency = 0.55
end

local function installKeyboardShortcuts()
    UserInputService.InputBegan:Connect(function(input, processed)
        if processed or not root then
            return
        end
        if input.KeyCode == Enum.KeyCode.Z then
            kyokaSuigetsu()
        elseif input.KeyCode == Enum.KeyCode.X then
            kurohitsugi()
        elseif input.KeyCode == Enum.KeyCode.C then
            raikoho()
        elseif input.KeyCode == Enum.KeyCode.V then
            shunpo()
        elseif input.KeyCode == Enum.KeyCode.B then
            reiatsuCrush()
        end
    end)
end

local function installAmbientAura()
    local auraAttachment = Instance.new("Attachment")
    auraAttachment.Name = "Aizen Reiatsu Anchor"
    auraAttachment.Parent = root

    local aura = Instance.new("ParticleEmitter")
    aura.Name = "Calm Absolute Reiatsu"
    aura.Color = ColorSequence.new(ACCENT, GOLD)
    aura.LightEmission = 0.8
    aura.Lifetime = NumberRange.new(0.8, 1.4)
    aura.Rate = 18
    aura.Speed = NumberRange.new(0.8, 2.2)
    aura.SpreadAngle = Vector2.new(25, 25)
    aura.Size = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0.25),
        NumberSequenceKeypoint.new(0.5, 0.08),
        NumberSequenceKeypoint.new(1, 0),
    })
    aura.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0.15),
        NumberSequenceKeypoint.new(1, 1),
    })
    aura.Parent = auraAttachment

    local connection
    connection = RunService.RenderStepped:Connect(function()
        if not root or not root.Parent then
            connection:Disconnect()
            return
        end
        auraAttachment.WorldCFrame = root.CFrame * CFrame.new(0, -2.5, 0)
    end)
end

createTool("Kyoka Suigetsu", "", 4, kyokaSuigetsu)
createTool("Hado 90: Kurohitsugi", "", 9, kurohitsugi)
createTool("Hado 63: Raikoho", "", 5, raikoho)
createTool("Shunpo", "", 3, shunpo)
createTool("Reiatsu Crush", "", 7, reiatsuCrush)
installKeyboardShortcuts()
installAmbientAura()

print("[Aizen FE] Tool suite loaded: Z Kyoka | X Kurohitsugi | C Raikoho | V Shunpo | B Reiatsu")
