	languageHolder.BackgroundTransparency = 1
	languageHolder.Position = UDim2.fromOffset(30, 166)
	languageHolder.Size = UDim2.new(1, -60, 0, 54)
	languageHolder.Visible = false
	languageHolder.Parent = card
	local layout = Instance.new("UIListLayout")
	layout.FillDirection = Enum.FillDirection.Horizontal
	layout.Padding = UDim.new(0, 10)
	layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	layout.Parent = languageHolder
	tween(bar, 1.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out, {Size = UDim2.fromScale(1, 1)})
	task.delay(1.28, function()
		subtitle.Text = TRANSLATIONS.en.pick
		languageHolder.Visible = true
		for code, text in pairs(TRANSLATIONS) do
			local button = Instance.new("TextButton")
			button.BackgroundColor3 = Color3.fromRGB(25, 16, 42)
			button.BorderSizePixel = 0
			button.Font = Enum.Font.GothamBlack
			button.Size = UDim2.fromOffset(78, 46)
			button.Text = text.button
			button.TextColor3 = WHITE
			button.TextScaled = true
			button.Parent = languageHolder
			local buttonCorner = Instance.new("UICorner")
			buttonCorner.CornerRadius = UDim.new(0, 12)
			buttonCorner.Parent = button
			local buttonStroke = Instance.new("UIStroke")
			buttonStroke.Color = GOLD
			buttonStroke.Transparency = 0.45
			buttonStroke.Parent = button
			button.MouseEnter:Connect(function()
				tween(button, 0.16, Enum.EasingStyle.Sine, Enum.EasingDirection.Out, {BackgroundColor3 = ACCENT})
			end)
			button.MouseLeave:Connect(function()
				tween(button, 0.16, Enum.EasingStyle.Sine, Enum.EasingDirection.Out, {BackgroundColor3 = Color3.fromRGB(25, 16, 42)})
			end)
			button.MouseButton1Click:Connect(function()
				selectedLanguage = code
				local chosen = TRANSLATIONS[selectedLanguage]
				subtitle.Text = chosen.ready
				notify(chosen.title, chosen.tip, 6)
				sendChatMessage(chosen.chat)
				flash(ACCENT, 0.16, 0.45)
				petalBurst(root.Position + Vector3.new(0, 3, 0), 28, GOLD, 0.75)
				tween(card, 0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.In, {Position = UDim2.fromScale(0.5, 0.44), BackgroundTransparency = 1})
				tween(shade, 0.35, Enum.EasingStyle.Sine, Enum.EasingDirection.In, {BackgroundTransparency = 1})
				Debris:AddItem(gui, 0.45)
				onComplete()
			end)
		end
	end)
end
local function installTools()
	createTool("Kyoka", "", 4, kyokaSuigetsu)
	createTool("Hado 90", "", 9, kurohitsugi)
	createTool("Raikoho", "", 5, raikoho)
	createTool("Shunpo", "", 3, shunpo)
	createTool("Reiatsu", "", 7, reiatsuCrush)
end
local function deathReset()
	humanoid.Died:Connect(function()
		airwalkActive=false
		airwalkDirection=Vector3.zero
		cleanupBin:ClearAllChildren()
		AnimController:SetState("Idle")
	end)
end
local function startKit()
	welcomeText()
	installRemoteSinks()
	installProceduralAnimationEngine()
	installTools()
	installKeyboardShortcuts()
	installAirwalkControls()
	installAmbientAura()
	installPassiveDominion()
	deathReset()
	player.CharacterAdded:Connect(function(newCharacter)
		task.wait(0.35)
		character = newCharacter
		humanoid = character:WaitForChild("Humanoid")
		root = character:WaitForChild("HumanoidRootPart")
		installProceduralAnimationEngine()
		installTools()
		installAmbientAura()
		deathReset()
	end)
	createIntroGui(function()
		local text = TRANSLATIONS[selectedLanguage]
		print("[Aizen FE] " .. text.ready .. " " .. text.tip)
	end)
end
createKeyGate(startKit)
