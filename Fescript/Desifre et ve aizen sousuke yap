        targets.rightHip = CF(0, 0, 0) * ANGLES(RAD(-18), 0, 0)
        targets.leftHip = CF(0, 0, 0) * ANGLES(RAD(18), 0, 0)
    elseif state == "Reiatsu" or state == "Hover" then
        targets.root = CF(0, math.sin(sine * 1.35) * 0.1, 0) * ANGLES(RAD(-6), 0, 0)
        targets.waist = CF(0, 0, 0) * ANGLES(RAD(-8), RAD(breathe * 2), 0)
        targets.neck = CF(0, 0, 0) * ANGLES(RAD(12), 0, 0)
        targets.rightShoulder = CF(0, 0, 0) * ANGLES(RAD(-35), 0, RAD(95 + breathe * 3))
        targets.leftShoulder = CF(0, 0, 0) * ANGLES(RAD(-35), 0, RAD(-95 - breathe * 3))
