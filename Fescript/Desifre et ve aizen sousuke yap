local function ghostClone(offset, lifetime)
    local wasArchivable = character.Archivable
    character.Archivable = true
    local clone = character:Clone()
    character.Archivable = wasArchivable
    clone.Name = "Kyoka Suigetsu Illusion"
    clone.Parent = cleanupBin

    for _, descendant in ipairs(clone:GetDescendants()) do
        if descendant:IsA("BasePart") then
            descendant.Anchored = true
            descendant.CanCollide = false
            descendant.CanTouch = false
            descendant.CanQuery = false
            descendant.Material = Enum.Material.ForceField
            descendant.Color = ACCENT
            descendant.Transparency = 0.35
            tween(descendant, lifetime, Enum.EasingStyle.Sine, Enum.EasingDirection.Out, {Transparency = 1})
        elseif descendant:IsA("Decal") or descendant:IsA("Texture") then
            descendant.Transparency = 0.8
        elseif descendant:IsA("Script") or descendant:IsA("LocalScript") then
            descendant:Destroy()
        end
    end

    clone:PivotTo(root.CFrame * CFrame.new(offset))
    Debris:AddItem(clone, lifetime + 0.1)
    return clone
end

local function publicPose(label, duration, velocity)
    if not humanoid or not root then
        return
    end

    humanoid.AutoRotate = false
    humanoid.Jump = true
    if velocity then
        root.AssemblyLinearVelocity = velocity
    end

    local marker = Instance.new("BillboardGui")
    marker.Name = "Public Aizen Pose"
    marker.Size = UDim2.fromOffset(240, 42)
    marker.StudsOffset = Vector3.new(0, 4.2, 0)
    marker.AlwaysOnTop = true
    marker.Parent = root

    local labelGui = Instance.new("TextLabel")
    labelGui.BackgroundTransparency = 1
    labelGui.Size = UDim2.fromScale(1, 1)
    labelGui.Font = Enum.Font.GothamBlack
    labelGui.Text = label
    labelGui.TextColor3 = WHITE
    labelGui.TextStrokeTransparency = 0.25
    labelGui.TextScaled = true
    labelGui.Parent = marker

    tween(labelGui, duration, Enum.EasingStyle.Sine, Enum.EasingDirection.Out, {TextTransparency = 1, TextStrokeTransparency = 1})
    Debris:AddItem(marker, duration + 0.1)

    task.delay(math.min(duration, 0.8), function()
        if humanoid then
            humanoid.AutoRotate = true
        end
    end)
end

local function cooldown(tool, seconds)
    if activeCooldowns[tool] then
        return false
    end

    activeCooldowns[tool] = true
    local originalName = tool.Name
    task.spawn(function()
        for remaining = seconds, 1, -1 do
            tool.Name = string.format("%s [%ds]", originalName, remaining)
            task.wait(1)
        end
        tool.Name = originalName
        activeCooldowns[tool] = nil
    end)

    return true
end

local function createTool(name, icon, cooldownSeconds, callback)
    local tool = Instance.new("Tool")
    tool.Name = name
    tool.ToolTip = KIT_NAME .. " | " .. name
    tool.TextureId = icon or ""
    tool.RequiresHandle = false
    tool.CanBeDropped = false
    tool.Parent = backpack

    tool.Activated:Connect(function()
        if not character or not root or humanoid.Health <= 0 then
            return
        end
        if cooldown(tool, cooldownSeconds) then
            callback(tool)
        end
    end)

    return tool
end

