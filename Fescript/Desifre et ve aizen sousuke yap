        tween(top, 0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.In, {Size = UDim2.new(1, 0, 0, 0)})
        tween(bottom, 0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.In, {Size = UDim2.new(1, 0, 0, 0)})
