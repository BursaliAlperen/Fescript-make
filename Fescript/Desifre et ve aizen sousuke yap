local function ghostClone(offset, lifetime)
    local wasArchivable = character.Archivable
    character.Archivable = true
    local clone = character:Clone()
    character.Archivable = wasArchivable
    clone.Name = "Kyoka Suigetsu Illusion"
    clone.Parent = cleanupBin

    for _, descendant in ipairs(clone:GetDescendants()) do
        if descendant:IsA("BasePart") then
            descendant.Anchored = true
            descendant.CanCollide = false
            descendant.CanTouch = false
            descendant.CanQuery = false
            descendant.Material = Enum.Material.ForceField
            descendant.Color = ACCENT
            descendant.Transparency = 0.35
            tween(descendant, lifetime, Enum.EasingStyle.Sine, Enum.EasingDirection.Out, {Transparency = 1})
        elseif descendant:IsA("Decal") or descendant:IsA("Texture") then
            descendant.Transparency = 0.8
        elseif descendant:IsA("Script") or descendant:IsA("LocalScript") then
            descendant:Destroy()
        end
    end

    clone:PivotTo(root.CFrame * CFrame.new(offset))
    Debris:AddItem(clone, lifetime + 0.1)
    return clone
end

