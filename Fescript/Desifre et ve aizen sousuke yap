local CF = CFrame.new
local ANGLES = CFrame.Angles
local RAD = math.rad

local function Clerp(a, b, t)
    return a:Lerp(b, math.clamp(t, 0, 1))
end

local AnimController = {
    State = "Idle",
    Sine = 0,
    Change = 1,
    StateEndsAt = 0,
    Motors = {},
    BaseC0 = {},
    Connected = false,
}

local function getMotor(name)
    for _, descendant in ipairs(character:GetDescendants()) do
        if descendant:IsA("Motor6D") and descendant.Name == name then
            return descendant
        end
    end
    return nil
end

local function captureMotor(name, ...)
    local aliases = {...}
    local motor = getMotor(name)
    for _, alias in ipairs(aliases) do
        motor = motor or getMotor(alias)
    end
    return motor
end

function AnimController:RefreshMotors()
    self.Motors = {
        root = captureMotor("RootJoint", "Root"),
        waist = captureMotor("Waist"),
        neck = captureMotor("Neck"),
        rightShoulder = captureMotor("RightShoulder", "Right Shoulder"),
        leftShoulder = captureMotor("LeftShoulder", "Left Shoulder"),
        rightHip = captureMotor("RightHip", "Right Hip"),
        leftHip = captureMotor("LeftHip", "Left Hip"),
    }

    self.BaseC0 = {}
    for key, motor in pairs(self.Motors) do
        if motor then
            self.BaseC0[key] = motor.C0
            motor.Transform = CFrame.new()
        end
    end
end

function AnimController:SetState(newState, duration)
    self.State = newState
    self.StateEndsAt = duration and (os.clock() + duration) or 0
end

function AnimController:AutoState()
    if not humanoid or not root then
        return "Idle"
    end

    local state = humanoid:GetState()
    if state == Enum.HumanoidStateType.Jumping then
        return "Jump"
    end
    if state == Enum.HumanoidStateType.Freefall then
        return root.AssemblyLinearVelocity.Y > 0 and "Jump" or "Fall"
    end

    local moving = humanoid.MoveDirection.Magnitude > 0.08
    local speed = Vector3.new(root.AssemblyLinearVelocity.X, 0, root.AssemblyLinearVelocity.Z).Magnitude
    if moving and speed > 18 then
        return "Run"
    end
    if moving then
        return "Walk"
    end
    return "Idle"
end

function AnimController:TargetPose(state)
    local sine = self.Sine
    local breathe = math.sin(sine * 1.7)
    local stride = math.sin(sine)
    local strideBack = math.sin(sine + math.pi)
    local targets = {}

    if state == "Idle" then
        targets.root = CF(0, 0, 0) * ANGLES(RAD(-2 + breathe * 1.2), 0, RAD(breathe * 0.6))
        targets.waist = CF(0, 0, 0) * ANGLES(RAD(1 + breathe * 1.5), RAD(breathe * 1.2), 0)
        targets.neck = CF(0, 0, 0) * ANGLES(RAD(-1 - breathe * 0.8), 0, 0)
        targets.rightShoulder = CF(0, 0, 0) * ANGLES(RAD(4 + breathe * 2), 0, RAD(5))
        targets.leftShoulder = CF(0, 0, 0) * ANGLES(RAD(4 - breathe * 2), 0, RAD(-5))
    elseif state == "Walk" then
        local softStep = math.sin(sine * 0.72)
        targets.root = CF(0, math.abs(stride) * 0.025, 0) * ANGLES(RAD(-1.5), 0, RAD(softStep * 0.7))
        targets.waist = CF(0, 0, 0) * ANGLES(RAD(1.5), RAD(softStep * 1.8), 0)
        targets.neck = CF(0, 0, 0) * ANGLES(RAD(-1.4), RAD(-softStep * 1.2), 0)
        targets.rightShoulder = CF(0, 0, 0) * ANGLES(RAD(-6 + breathe * 1.2), RAD(0), RAD(10 + softStep * 1.4))
        targets.leftShoulder = CF(0, 0, 0) * ANGLES(RAD(-6 - breathe * 1.2), RAD(0), RAD(-10 + softStep * 1.4))
        targets.rightHip = CF(0, 0, 0) * ANGLES(RAD(stride * 18), 0, RAD(-1.5))
        targets.leftHip = CF(0, 0, 0) * ANGLES(RAD(strideBack * 18), 0, RAD(1.5))
    elseif state == "Run" then
        local dashStep = math.sin(sine * 1.18)
        targets.root = CF(0, math.abs(stride) * 0.045, 0) * ANGLES(RAD(-8), 0, RAD(dashStep * 1.8))
        targets.waist = CF(0, 0, 0) * ANGLES(RAD(5), RAD(dashStep * 3.5), 0)
        targets.neck = CF(0, 0, 0) * ANGLES(RAD(-6), RAD(-dashStep * 2), 0)
        targets.rightShoulder = CF(0, 0, 0) * ANGLES(RAD(-24 + strideBack * 8), RAD(0), RAD(22))
        targets.leftShoulder = CF(0, 0, 0) * ANGLES(RAD(-24 + stride * 8), RAD(0), RAD(-22))
        targets.rightHip = CF(0, 0, 0) * ANGLES(RAD(stride * 34), 0, RAD(-2))
        targets.leftHip = CF(0, 0, 0) * ANGLES(RAD(strideBack * 34), 0, RAD(2))
    elseif state == "Jump" then
        targets.root = CF(0, 0, 0) * ANGLES(RAD(-10), 0, 0)
        targets.neck = CF(0, 0, 0) * ANGLES(RAD(-8), 0, 0)
        targets.rightShoulder = CF(0, 0, 0) * ANGLES(RAD(-34), 0, RAD(16))
        targets.leftShoulder = CF(0, 0, 0) * ANGLES(RAD(-34), 0, RAD(-16))
        targets.rightHip = CF(0, 0, 0) * ANGLES(RAD(18), 0, 0)
        targets.leftHip = CF(0, 0, 0) * ANGLES(RAD(-10), 0, 0)
    elseif state == "Fall" then
        targets.root = CF(0, 0, 0) * ANGLES(RAD(12), 0, 0)
        targets.neck = CF(0, 0, 0) * ANGLES(RAD(8), 0, 0)
        targets.rightShoulder = CF(0, 0, 0) * ANGLES(RAD(18), 0, RAD(45))
        targets.leftShoulder = CF(0, 0, 0) * ANGLES(RAD(18), 0, RAD(-45))
        targets.rightHip = CF(0, 0, 0) * ANGLES(RAD(-8), 0, 0)
        targets.leftHip = CF(0, 0, 0) * ANGLES(RAD(12), 0, 0)
    elseif state == "Charge" then
        targets.root = CF(0, 0, 0) * ANGLES(RAD(-8 + breathe * 2), 0, 0)
        targets.waist = CF(0, 0, 0) * ANGLES(RAD(-10), RAD(breathe * 3), 0)
        targets.neck = CF(0, 0, 0) * ANGLES(RAD(8), 0, 0)
        targets.rightShoulder = CF(0, 0, 0) * ANGLES(RAD(-78), RAD(0), RAD(70 + breathe * 4))
        targets.leftShoulder = CF(0, 0, 0) * ANGLES(RAD(-78), RAD(0), RAD(-70 - breathe * 4))
    elseif state == "Kurohitsugi" then
        targets.root = CF(0, math.sin(sine * 1.5) * 0.08, 0) * ANGLES(RAD(-10), 0, 0)
        targets.waist = CF(0, 0, 0) * ANGLES(RAD(-16), 0, 0)
