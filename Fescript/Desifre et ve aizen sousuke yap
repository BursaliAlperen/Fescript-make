local function cooldown(tool, seconds)
	if activeCooldowns[tool] then
		return false
	end
	activeCooldowns[tool] = true
	local originalName = tool.Name
	task.spawn(function()
		for remaining = seconds, 1, -1 do
			tool.Name = string.format("%s [%ds]", originalName, remaining)
			task.wait(1)
		end
		tool.Name = originalName
		activeCooldowns[tool] = nil
	end)
	return true
end
local function createTool(name, icon, cooldownSeconds, callback)
	local tool = Instance.new("Tool")
	tool.Name = name
	tool.ToolTip = KIT_NAME .. " | " .. name
	tool.TextureId = icon or ""
	tool.RequiresHandle = false
	tool.CanBeDropped = false
	tool.Parent = backpack
	tool.Activated:Connect(function()
		if not character or not root or humanoid.Health <= 0 then
			return
		end
		if cooldown(tool, cooldownSeconds) then
			callback(tool)
		end
	end)
	return tool
end
