local function ring(cframe, radius, color, lifetime, thickness)
    local part = makePart("Spiritual Pressure Ring", Vector3.new(radius, thickness or 0.18, radius), cframe, color, Enum.Material.Neon, 0.18)
    part.Shape = Enum.PartType.Cylinder
    tween(part, lifetime, Enum.EasingStyle.Quint, Enum.EasingDirection.Out, {
        Size = Vector3.new(radius * 2.1, thickness or 0.18, radius * 2.1),
        Transparency = 1,
    })
    Debris:AddItem(part, lifetime + 0.1)
    return part
end

local function orb(position, radius, color, lifetime)
    local part = makePart("Reiatsu Orb", Vector3.new(radius, radius, radius), CFrame.new(position), color, Enum.Material.Neon, 0.05)
    part.Shape = Enum.PartType.Ball
    tween(part, lifetime, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out, {
        Size = Vector3.new(radius * 2.8, radius * 2.8, radius * 2.8),
