local function ring(cframe, radius, color, lifetime, thickness)
    local part = makePart("Spiritual Pressure Ring", Vector3.new(radius, thickness or 0.18, radius), cframe, color, Enum.Material.Neon, 0.18)
    part.Shape = Enum.PartType.Cylinder
    tween(part, lifetime, Enum.EasingStyle.Quint, Enum.EasingDirection.Out, {
        Size = Vector3.new(radius * 2.1, thickness or 0.18, radius * 2.1),
        Transparency = 1,
    })
    Debris:AddItem(part, lifetime + 0.1)
    return part
end

local function orb(position, radius, color, lifetime)
    local part = makePart("Reiatsu Orb", Vector3.new(radius, radius, radius), CFrame.new(position), color, Enum.Material.Neon, 0.05)
    part.Shape = Enum.PartType.Ball
    tween(part, lifetime, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out, {
        Size = Vector3.new(radius * 2.8, radius * 2.8, radius * 2.8),
        Transparency = 1,
    })
    Debris:AddItem(part, lifetime + 0.05)
    return part
end

local function beamBetween(name, startPosition, endPosition, color, width, lifetime)
    local midpoint = (startPosition + endPosition) / 2
    local distance = (startPosition - endPosition).Magnitude
    local part = makePart(name, Vector3.new(width, width, distance), CFrame.new(midpoint, endPosition), color, Enum.Material.Neon, 0.08)
    tween(part, lifetime, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, {
        Size = Vector3.new(width * 0.15, width * 0.15, distance),
        Transparency = 1,
    })
    Debris:AddItem(part, lifetime + 0.05)
    return part
end

local function sigil(cframe, radius, color, lifetime, spokes)
    ring(cframe, radius, color, lifetime, 0.08)
    for i = 1, spokes or 12 do
        local angle = (math.pi * 2 / (spokes or 12)) * i
        local startPosition = (cframe * CFrame.new(math.cos(angle) * radius * 0.15, 0, math.sin(angle) * radius * 0.15)).Position
        local endPosition = (cframe * CFrame.new(math.cos(angle) * radius, 0, math.sin(angle) * radius)).Position
        task.delay(i * 0.01, function()
            beamBetween("Reiatsu Sigil Line", startPosition, endPosition, color, 0.06, lifetime * 0.7)
        end)
    end
end

local function petalBurst(origin, count, color, lifetime)
    for i = 1, count do
        local petal = makePart("Kyoka Petal", Vector3.new(0.08, 0.02, 0.35), CFrame.new(origin), color, Enum.Material.Neon, 0.15)
        local spread = Vector3.new(rng:NextNumber(-9, 9), rng:NextNumber(1, 7), rng:NextNumber(-9, 9))
        petal.CFrame = CFrame.new(origin, origin + spread) * CFrame.Angles(rng:NextNumber(-3, 3), rng:NextNumber(-3, 3), rng:NextNumber(-3, 3))
        tween(petal, lifetime, Enum.EasingStyle.Sine, Enum.EasingDirection.Out, {
            CFrame = petal.CFrame + spread,
            Transparency = 1,
        })
        Debris:AddItem(petal, lifetime + 0.1)
    end
end

