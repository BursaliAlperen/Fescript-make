local function tween(instance, time, style, direction, properties)
    local info = TweenInfo.new(time, style or Enum.EasingStyle.Quad, direction or Enum.EasingDirection.Out)
    local animation = TweenService:Create(instance, info, properties)
    animation:Play()
    return animation
end

local function notify(title, text, duration)
    task.spawn(function()
        pcall(function()
            StarterGui:SetCore("SendNotification", {
                Title = title,
                Text = text,
                Duration = duration or 5,
            })
        end)
    end)
end

local function sendChatMessage(message)
    if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
        local channels = TextChatService:FindFirstChild("TextChannels")
        local general = channels and channels:FindFirstChild("RBXGeneral")
        if general then
            local ok = pcall(function()
                general:SendAsync(message)
            end)
            if ok then
                return true
            end
        end
    end

    local events = ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents")
    local sayMessage = events and events:FindFirstChild("SayMessageRequest")
    if sayMessage then
        sayMessage:FireServer(message, "All")
        return true
    end

    return false
end

local function makePart(name, size, cframe, color, material, transparency)
    local part = Instance.new("Part")
    part.Name = name
    part.Anchored = true
    part.CanCollide = false
    part.CanTouch = false
    part.CanQuery = false
    part.CastShadow = false
    part.Size = size
    part.CFrame = cframe
    part.Color = color
    part.Material = material or Enum.Material.Neon
    part.Transparency = transparency or 0
    part.Parent = cleanupBin
    return part
end

local function makeSound(name, soundId, volume, speed, parent)
    local sound = Instance.new("Sound")
    sound.Name = name
    sound.SoundId = soundId
    sound.Volume = volume or 0.6
    sound.PlaybackSpeed = speed or 1
    sound.RollOffMaxDistance = 110
    sound.Parent = parent or root
    sound:Play()
    Debris:AddItem(sound, 6)
    return sound
end

local function flash(color, intensity, duration)
    local effect = Instance.new("ColorCorrectionEffect")
    effect.Name = "AizenFlash"
    effect.TintColor = color
    effect.Brightness = intensity
    effect.Contrast = 0.25
    effect.Saturation = -0.05
    effect.Parent = Lighting
    tween(effect, duration, Enum.EasingStyle.Sine, Enum.EasingDirection.Out, {
        Brightness = 0,
        Contrast = 0,
        Saturation = 0,
        TintColor = Color3.new(1, 1, 1),
    })
    Debris:AddItem(effect, duration + 0.15)
end

local function cameraPulse(power, duration)
    local camera = workspace.CurrentCamera
    if not camera then
        return
    end

    local start = os.clock()
    local original = camera.CFrame
    local connection
    connection = RunService.RenderStepped:Connect(function()
        local alpha = (os.clock() - start) / duration
        if alpha >= 1 then
            camera.CFrame = original
            connection:Disconnect()
            return
        end

        local falloff = 1 - alpha
        local shake = Vector3.new(
            rng:NextNumber(-power, power),
            rng:NextNumber(-power, power),
            rng:NextNumber(-power, power)
        ) * falloff
        camera.CFrame = camera.CFrame * CFrame.new(shake)
    end)
end

